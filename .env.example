# Deevo Cortex — Environment Variables
# Copy this file to .env and update values for your environment.
# NEVER commit the .env file — it may contain secrets.

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://deevo:your_password_here@localhost:5432/deevo_cortex
DATABASE_URL_SYNC=postgresql://deevo:your_password_here@localhost:5432/deevo_cortex

# ─── Backend Server ────────────────────────────────────────
APP_ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Ollama (optional — LLM-enhanced reasoning) ───────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Calibration ───────────────────────────────────────────
CALIBRATION_MODE=semi_auto
EMA_ALPHA=0.3

# ─── Market Scope ──────────────────────────────────────────
DEFAULT_MARKET=KWT
DEFAULT_PORTFOLIO=motor_retail
