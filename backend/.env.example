# Deevo Cortex — Kuwait Motor Adaptive Risk Engine
# Copy this to .env and update values

# Database
DATABASE_URL=postgresql://deevo:deevo@localhost:5432/deevo_cortex

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Calibration
CALIBRATION_MODE=semi_auto
EMA_ALPHA=0.3

# Market
DEFAULT_MARKET=KWT
DEFAULT_PORTFOLIO=motor_retail
